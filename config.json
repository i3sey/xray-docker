{
  "log": {
    "loglevel": "none"
  },
  "inbounds": [
    {
      "tag": "proxy-in",
      "port": 3002,
      "listen": "0.0.0.0",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "${PROXY_TARGET_HOST}",
        "port": 3001,
        "network": "tcp,udp"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ]
}